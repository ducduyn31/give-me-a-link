{
  "manifest_version": 3,
  "name": "GiveMeALink — Copy as Markdown Link",
  "version": "1.1.1",
  "description": "Copy the current page as a Markdown link. Cmd+. on macOS, Ctrl+. elsewhere.",
  "author": "danielng",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "commands": {
    "copy-markdown-link": {
      "suggested_key": {
        "default": "Ctrl+Period",
        "mac": "Command+Period"
      },
      "description": "Copy current page as Markdown link to clipboard"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "give-me-a-link@local"
    }
  }
}
