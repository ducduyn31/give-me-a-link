{
  "manifest_version": 3,
  "name": "GiveMeALink — Copy as Markdown Link",
  "version": "1.3.0",
  "description": "Copy the current page as a Markdown link. Cmd+. on macOS, Ctrl+. elsewhere.",
  "author": "danielng",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting", "storage", "offscreen"],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/blob/*"],
      "js": ["github-menu.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "commands": {
    "copy-markdown-link": {
      "suggested_key": {
        "default": "Ctrl+Period",
        "mac": "Command+Period"
      },
      "description": "Copy current page as Markdown link to clipboard"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "give-me-a-link@coffeewithegg.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
