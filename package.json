{
  "name": "give-me-a-link",
  "version": "1.4.0",
  "private": true,
  "description": "Copy the current page as a Markdown link to the clipboard.",
  "license": "MIT",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsc",
    "test": "bun test",
    "build": "bun scripts/build.ts",
    "package": "bun scripts/package.ts",
    "verify": "bun run lint && bun run format:check && bun run typecheck && bun test",
    "changeset": "changeset",
    "version": "changeset version && bun scripts/sync-manifest-version.ts && bun run format",
    "release": "bun scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
